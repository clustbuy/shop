<!-- Main Content -->
<main class="main-certificate">
    <div class="container">
        <section class="content order-page">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-lg-12 no-margin">

                        <h1>Как оформить заказ</h1>

                        <div class="order-card">
                            <div class="order-content">

                                <p>
                                    Заходите в <a href="/catalog/">каталог товаров</a> и выбирайте, что душе угодно. Покупку можно сделать на любую сумму, но мы рекомендуем сумму <strong>не меньше 300 руб</strong>.
                                </p>

                                <p>
                                    Рассчитывайте, что к сумме покупки может добавиться стоимость доставки.
                                </p>

                                <p>
                                    После наполнения корзины покупателя нажмите на кнопку <strong>"Начать оформление заказа"</strong>.
                                </p>

                                <div class="order-note">
                                    Ознакомиться со способами доставки можно <a href="/delivery/">Здесь</a>.
                                </div>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </section>
    </div>
</main>

