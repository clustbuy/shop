function get_categories(node, section_name)
{
	
	$.ajax({
	    type: 'POST',
	    url: "/",
	    dataType: 'json',
	    data: {
	        ajax: 1,
	        task: 'get_categories',
	        root: node
	    },
	    async: false,
	    cache: false,
	    error: function (jqXHR, textStatus) {
	        console.log("Нет связи с сервером: " + textStatus);
	    },
	    success: function (data) {

	    	console.log(data);

				$('.catalog__categories').html('');
				$('.catalog__title').html(section_name);

				data.forEach(function(e){
					var ul = document.createElement('ul');
					ul.setAttribute('class', 'categories-menu items-carousel');
					ul.innerHTML = `
						<li class="categories-menu__title">
							<a href="/category/${e.guid}/" class="categories-menu__link">${e.title}</a>
						</li>
					`;

					e.childrens.forEach(function(element, index){

						var li = document.createElement('li');
						li.setAttribute('class', 'categories-menu__item');
						li.innerHTML = `
							<a href="/category/${element.guid}/" class="categories-menu__link">${element.title} `+/*${element.items_count}+*/`</a>`;

						if (index > 4) {
							li.classList.add('link-hide', 'hidden');
						}

						ul.append(li);

						if (index > 4) {

							if (index === e.childrens.length - 1) {
								var more = document.createElement('li');
								more.setAttribute('class', 'categories-menu__item');
								more.innerHTML = `
									<a href="#" class="categories-menu__link categories-menu__link--more close" onclick="viewMoreItems(this)">
										<span>Ещё</span>
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" class="dg"><path fill="currentColor" d="M6.293 9.293a1 1 0 0 1 1.414 0L12 13.586l4.293-4.293a1 1 0 1 1 1.414 1.414l-5 5a1 1 0 0 1-1.414 0l-5-5a1 1 0 0 1 0-1.414Z"></path></svg>
									</a>
								`;
								ul.append(more);
							}
						}
					});

					$('.catalog__categories').append(ul);

				});

				//makeTabsSameHeight();
				$(".js-catalog").css('display', 'block');

	    }
	});
}

function viewMoreItems(e) {
	if ($(e).hasClass('close')) {
		$(e).removeClass('close');
		$(e).find('span').text('Свернуть');
		$(e).find('svg').css('transform', 'rotate(180deg)');
		$(e).closest('ul').children().each((index, element) => {
			if ($(element).hasClass('hidden')) $(element).removeClass('hidden')
		})
	} else {
		$(e).addClass('close');
		$(e).find('span').text('Ещё');
		$(e).find('svg').css('transform', 'rotate(0)');
		$(e).closest('ul').children().each((index, element) => {
			if ($(element).hasClass('link-hide')) $(element).addClass('hidden')
		})
	}
}
