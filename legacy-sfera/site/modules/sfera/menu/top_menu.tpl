<script>

function makeTabsSameHeight() {
    function setEqualHeight(tabs) {
      var maxHeight = 0;
  
      tabs.each(function() {
        currentHeight = $(this).outerHeight();
        if (currentHeight > maxHeight) {
          maxHeight = currentHeight;
        }
      });
  
      tabs.height(maxHeight);
    }
    setEqualHeight($(".categories-menu"));
}

