                        <script>
                            document.addEventListener('DOMContentLoaded', function() {
                                const carousels = document.querySelectorAll('[data-widget="advBanner"].rtb_f6');

                                carousels.forEach(carousel => {
                                    const sliderWrapper = carousel.querySelector('.a35_3_1-a2');
                                    const slidesContainer = carousel.querySelector('.a35_3_1-a4');
                                    const slides = carousel.querySelectorAll('.rtb_f7');
                                    const prevBtn = carousel.querySelector('.a35_3_1-b1');
                                    const nextBtn = carousel.querySelector('.a35_3_1-b2');

                                    let currentIndex = 0;
                                    let slideWidth = 0;
                                    let isAnimating = false;

                                    // Инициализация карусели
                                    function initCarousel() {
                                        // Рассчитываем ширину слайда
                                        slideWidth = sliderWrapper.offsetWidth;

                                        // Устанавливаем ширину контейнера слайдов
                                        slidesContainer.style.width = `${slideWidth * slides.length}px`;

                                        // Устанавливаем ширину каждого слайда
                                        slides.forEach(slide => {
                                            slide.style.width = `${slideWidth}px`;
                                            slide.style.flexShrink = '0';
                                        });

                                        // Показываем первый слайд
                                        goToSlide(0);
                                    }

                                    // Функция переключения слайдов
                                    function goToSlide(index) {
                                        if (isAnimating) return;

                                        // Корректируем индекс для зацикливания
                                        if (index < 0) index = slides.length - 1;
                                        else if (index >= slides.length) index = 0;

                                        isAnimating = true;
                                        currentIndex = index;

                                        // Рассчитываем смещение
                                        const offset = -currentIndex * slideWidth;

                                        // Применяем анимацию
                                        slidesContainer.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
                                        slidesContainer.style.transform = `translateX(${offset}px)`;

                                        // Сбрасываем флаг анимации после завершения
                                        setTimeout(() => {
                                            isAnimating = false;
                                        }, 500);
                                    }

                                    // Обработчики кнопок
                                    prevBtn.addEventListener('click', () => {
                                        goToSlide(currentIndex - 1);
                                    });

                                    nextBtn.addEventListener('click', () => {
                                        goToSlide(currentIndex + 1);
                                    });

                                    // Автопрокрутка
                                    let autoplayInterval = setInterval(() => {
                                        if (!isAnimating) goToSlide(currentIndex + 1);
                                    }, 5000);

                                    // Пауза при наведении
                                    carousel.addEventListener('mouseenter', () => {
                                        clearInterval(autoplayInterval);
                                    });

                                    carousel.addEventListener('mouseleave', () => {
                                        autoplayInterval = setInterval(() => {
                                            if (!isAnimating) goToSlide(currentIndex + 1);
                                        }, 5000);
                                    });

                                    // Обработка изменения размеров окна
                                    window.addEventListener('resize', () => {
                                        // Пересчитываем размеры
                                        slideWidth = sliderWrapper.offsetWidth;
                                        slidesContainer.style.width = `${slideWidth * slides.length}px`;

                                        slides.forEach(slide => {
                                            slide.style.width = `${slideWidth}px`;
                                        });

                                        // Возвращаемся к текущему слайду
                                        goToSlide(currentIndex);
                                    });

                                    // Инициализируем карусель
                                    initCarousel();
                                });
                            });
                        </script>
