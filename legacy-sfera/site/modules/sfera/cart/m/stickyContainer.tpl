<script>

    var block_show = true;
    var wih = window.innerHeight;

    function scrollTracking(){
        var wt = $(window).scrollTop();
        var et = $('.order_btn').offset().top;

        if (et > wt + wih){
            if (block_show == null || block_show == true) {
                $('.sticky_total').show();
                /*console.log('show');*/
            }
            block_show = true;
            /*console.log(wt + ' ' + Number(et - wih));*/

        } else {

            if (block_show == null || block_show == false) {

                /*console.log('hide');*/
                $('.sticky_total').hide();
            }
            block_show = false;
            /*console.log(wt + ' ' + Number(et - wih));*/

        }
    }

    $(window).scroll(function(){
        scrollTracking();
    });

    $(document).ready(function(){
        scrollTracking();
    });

</script>
