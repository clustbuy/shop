<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Основные элементы
        const carousel = document.querySelector('[data-widget="advBanner"]');
        if (!carousel) return;

        const slidesContainer = carousel.querySelector('.rtb_e8');
        const slides = carousel.querySelectorAll('.rtb_e9');
        const prevBtn = carousel.querySelector('.carousel-prev');
        const nextBtn = carousel.querySelector('.carousel-next');
        const indicatorsContainer = carousel.querySelector('.carousel-indicators');

        // Переменные состояния
        let currentIndex = 0;
        let autoplayInterval = null;
        let isSwiping = false;
        let touchStartX = 0;
        let touchCurrentX = 0;
        const swipeThreshold = 50;
        const allowLooping = true; // Зацикливание карусели
        const autoplayDelay = 5000; // 5 секунд

        // Инициализация карусели
        function initCarousel() {
            createIndicators();
            updateCarousel();
            startAutoplay();
            addSwipeSupport();
            setupEventListeners();
        }

        // Создание индикаторов
        function createIndicators() {
            indicatorsContainer.innerHTML = '';

            slides.forEach((_, index) => {
                const indicator = document.createElement('div');
                indicator.classList.add('indicator');
                indicator.addEventListener('click', () => goToSlide(index));
                indicatorsContainer.appendChild(indicator);
            });
        }

        // Переход к конкретному слайду
        function goToSlide(index) {
            // Корректировка индекса для зацикливания
            if (allowLooping) {
                if (index < 0) index = slides.length - 1;
                if (index >= slides.length) index = 0;
            } else {
                index = Math.max(0, Math.min(index, slides.length - 1));
            }

            currentIndex = index;
            updateCarousel();
            restartAutoplay();
        }

        // Обновление визуального состояния
        function updateCarousel() {
            // Перемещение карусели
            slidesContainer.style.transform = `translateX(-${currentIndex * 100}%)`;

            // Обновление индикаторов
            document.querySelectorAll('.indicator').forEach((indicator, i) => {
                indicator.classList.toggle('active', i === currentIndex);
            });
        }

        // Автопрокрутка
        function startAutoplay() {
            if (autoplayInterval) clearInterval(autoplayInterval);
            autoplayInterval = setInterval(() => goToSlide(currentIndex + 1), autoplayDelay);
        }

        function restartAutoplay() {
            clearInterval(autoplayInterval);
            startAutoplay();
        }

        function pauseAutoplay() {
            clearInterval(autoplayInterval);
        }

        // Обработчики событий
        function setupEventListeners() {
            // Кнопки навигации
            prevBtn.addEventListener('click', () => goToSlide(currentIndex - 1));
            nextBtn.addEventListener('click', () => goToSlide(currentIndex + 1));

            // Пауза при взаимодействии
            carousel.addEventListener('mouseenter', pauseAutoplay);
            carousel.addEventListener('mouseleave', startAutoplay);
            carousel.addEventListener('touchstart', pauseAutoplay);
        }

        // Поддержка свайпа
        function addSwipeSupport() {
            slidesContainer.addEventListener('touchstart', handleTouchStart);
            slidesContainer.addEventListener('touchmove', handleTouchMove);
            slidesContainer.addEventListener('touchend', handleTouchEnd);
        }

        function handleTouchStart(e) {
            touchStartX = e.touches[0].clientX;
            touchCurrentX = touchStartX;
            isSwiping = true;

            // Временно отключаем переход для плавного свайпа
            slidesContainer.style.transition = 'none';
        }

        function handleTouchMove(e) {
            if (!isSwiping) return;

            touchCurrentX = e.touches[0].clientX;
            const diff = touchCurrentX - touchStartX;

            // Промежуточная позиция во время свайпа
            slidesContainer.style.transform = `translateX(calc(-${currentIndex * 100}% + ${diff}px))`;

            // Блокируем вертикальный скролл
            if (Math.abs(diff) > 10) {
                e.preventDefault();
            }
        }

        function handleTouchEnd() {
            if (!isSwiping) return;
            isSwiping = false;

            // Восстанавливаем переход
            slidesContainer.style.transition = '';

            const diff = touchCurrentX - touchStartX;

            // Определяем направление
            if (Math.abs(diff) > swipeThreshold) {
                if (diff > 0) {
                    goToSlide(currentIndex - 1); // Свайп вправо
                } else {
                    goToSlide(currentIndex + 1); // Свайп влево
                }
            } else {
                // Возврат к текущему слайду
                goToSlide(currentIndex);
            }
        }

        // Адаптация для мобильных
        function adaptForMobile() {
            if ('ontouchstart' in window) {
                // Увеличиваем зону клика для индикаторов
                document.querySelectorAll('.indicator').forEach(ind => {
                    ind.style.width = '14px';
                    ind.style.height = '14px';
                });
            }
        }

        // Запускаем карусель
        initCarousel();
        adaptForMobile();
    });
</script>


